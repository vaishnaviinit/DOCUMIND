# ─── LLM provider ─────────────────────────
LLM_PROVIDER=openai          # openai | gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Embeddings ───────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector store (ChromaDB) ──────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─── Chunking / retrieval ─────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# ─── Callback to backend ──────────────────
BACKEND_URL=http://localhost:5000/api
